{
  "name": "@lifanh/pi-langfuse-extension",
  "version": "0.1.3",
  "description": "Langfuse observability extension for Pi Coding Agent",
  "type": "module",
  "packageManager": "npm@11.7.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./redaction": {
      "types": "./dist/src/redaction.d.ts",
      "import": "./dist/src/redaction.js"
    },
    "./config": {
      "types": "./dist/src/config.d.ts",
      "import": "./dist/src/config.js"
    },
    "./capture-policy": {
      "types": "./dist/src/capture-policy.d.ts",
      "import": "./dist/src/capture-policy.js"
    }
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "langfuse",
    "observability",
    "tracing",
    "privacy"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.0.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifanh/pi-langfuse-extension.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
